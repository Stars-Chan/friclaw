{
  "name": "friclaw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "restart": "bun run src/index.ts restart",
    "stop": "bun run src/index.ts stop",
    "status": "bun run src/index.ts status",
    "dev": "bun --watch src/index.ts",
    "init": "bun run src/index.ts onboard",
    "weixin-login": "bun run src/index.ts weixin-login",
    "mcp:cron": "bun run src/mcp/cron-entry.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "postinstall": "cd src/web && npm install --registry=https://registry.npmmirror.com"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/ws": "^8.18.1",
    "croner": "^10.0.1",
    "luxon": "^3.7.2",
    "pino": "^9.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/luxon": "^3.7.1",
    "typescript": "^5.4.0"
  }
}
